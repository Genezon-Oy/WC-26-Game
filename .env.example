# Supabase Configuration
# Public keys exposed to the client (required for both local development and production)
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Server-side environment variables (used by TanStack Start backend server functions)
# Keep these secure and do NOT commit them to public version control!
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Third-Party Sports APIs (Required for syncing live matches and odds in Admin view)
# 1. API Key for https://www.football-data.org (Free tier available, used for live score sync)
FOOTBALL_DATA_API_KEY="your-football-data-api-key"

# 2. API Key for https://api.the-odds-api.com (The Odds API, used for odds sync)
ODDS_API_KEY="your-the-odds-api-key"
